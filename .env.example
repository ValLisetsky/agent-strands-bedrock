# Runtime mode: "local" (Ollama) or "cloud" (AWS Bedrock)
AGENT_MODE=local

# Local mode: Ollama model name
LOCAL_MODEL_NAME=qwen2.5:7b-instruct

# Cloud mode: AWS Bedrock model ID
CLOUD_MODEL_NAME=anthropic.claude-haiku-4-5-20251001-v1:0

# Cloud mode: AWS configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
