# Runtime mode: "local" (Ollama) or "cloud" (AWS Bedrock)
AGENT_MODE=local

# Local mode: Ollama model name
LOCAL_MODEL_NAME=qwen2.5:7b-instruct

# Cloud mode: AWS Bedrock model ID
CLOUD_MODEL_NAME=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Cloud mode: AWS configuration
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AgentCore: memory resource ID (from setup_memory.py)
AGENTCORE_MEMORY_ID=
# AgentCore: execution role ARN (arn:aws:iam::<account-id>:role/AgentCoreRuntimeRole)
AGENTCORE_RUNTIME_ROLE_ARN=
